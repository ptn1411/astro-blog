---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { ClientPreviewStories } from '~/components/admin/story';
import type { Story } from '~/components/admin/story/types';
import Layout from '~/layouts/Layout.astro';

export const prerender = true;

// Load all assets using glob — must be top-level for Vite static analysis
const images = import.meta.glob('/src/assets/images/**/*', {
  eager: false,
  import: 'default',
});

const audios = import.meta.glob('/src/assets/audio/**/*', {
  eager: false,
  import: 'default',
});

const videos = import.meta.glob('/src/assets/video/**/*', {
  eager: false,
  import: 'default',
});

// Helper: resolve /src/assets/... paths → hashed production URLs
const resolveAsset = async (assetPath: string, assetsGlob: Record<string, () => Promise<unknown>>) => {
  if (!assetPath || !assetPath.startsWith('/src/assets/')) return assetPath;
  try {
    const fileName = assetPath.split('/').pop() ?? '';
    const matchingKey = Object.keys(assetsGlob).find((k) => k.includes(fileName));
    if (matchingKey) {
      const mod = (await assetsGlob[matchingKey]()) as { src?: string } | string;
      return (mod as { src?: string }).src ?? (mod as string);
    }
  } catch {
    // silently fall back to original path
  }
  return assetPath;
};

export const getStaticPaths = (async () => {
  const stories = await getCollection('stories');

  return Promise.all(
    stories.map(async (story) => {
      const storyData = JSON.parse(JSON.stringify(story.data)) as Story;

      for (const slide of storyData.slides ?? []) {
        if (slide.background?.type === 'image' && slide.background.value)
          slide.background.value = await resolveAsset(slide.background.value, images);
        if (slide.background?.type === 'video' && slide.background.value)
          slide.background.value = await resolveAsset(slide.background.value, videos);
        if (slide.audio?.src)
          slide.audio.src = await resolveAsset(slide.audio.src, audios);

        for (const el of slide.elements ?? []) {
          if (['image', 'sticker', 'gif', 'avatar'].includes(el.type)) {
            if (el.content) el.content = await resolveAsset(el.content, images);
            if (el.src)     el.src     = await resolveAsset(el.src, images);
          }
          if (el.type === 'video') {
            if (el.content) el.content = await resolveAsset(el.content, videos);
            if (el.src)     el.src     = await resolveAsset(el.src, videos);
          }
          if (el.type === 'audio') {
            if (el.content) el.content = await resolveAsset(el.content, audios);
            if (el.src)     el.src     = await resolveAsset(el.src, audios);
          }
          if (el.type === 'slider') {
            for (const img of el.slider?.images ?? [])
              if (img.src) img.src = await resolveAsset(img.src, images);
          }
          if (el.type === 'carousel') {
            const imgs: string[] = el.carousel?.images ?? [];
            for (let i = 0; i < imgs.length; i++)
              imgs[i] = await resolveAsset(imgs[i], images);
          }
        }
      }

      return {
        params: { id: story.id },
        props: { story: storyData },
      };
    })
  );
}) satisfies GetStaticPaths;

type Props = {
  story: Story;
};

const { story } = Astro.props as Props;

if (!story) {
  return Astro.redirect('/stories');
}

const metadata = {
  title: story.title || `Story: ${story.id}`,
  description: story.description || 'View an interactive story created with Story Builder.',
  canonical: new URL(Astro.url.pathname, Astro.site).toString(),
};
---

<Layout metadata={metadata}>
  <div class="min-h-screen bg-black w-full">
    <ClientPreviewStories story={story} client:only="react" />
  </div>
  <style>
    :global(body) {
      margin: 0;
      padding: 0;
      overflow: hidden;
    }
  </style>
</Layout>
